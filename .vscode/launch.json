{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug FastAPI (uvicorn, no-reload)",
      "type": "python",
      "request": "launch",
      "module": "uvicorn",
      "cwd": "${workspaceFolder}/backend",
      "args": ["app.main:app", "--host", "0.0.0.0", "--port", "8000"],
      "envFile": "${workspaceFolder}/backend/.env",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/backend",
        "PYTHONUNBUFFERED": "1"
      },
      "justMyCode": false,
      "console": "integratedTerminal"
    },
    {
      "name": "Debug FastAPI (uvicorn, reload)",
      "type": "python",
      "request": "launch",
      "module": "uvicorn",
      "cwd": "${workspaceFolder}/backend",
      "args": ["app.main:app", "--reload", "--host", "0.0.0.0", "--port", "8000"],
      "envFile": "${workspaceFolder}/backend/.env",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/backend",
        "PYTHONUNBUFFERED": "1"
      },
      "subProcess": true,
      "justMyCode": false,
      "console": "integratedTerminal"
    }
  ]
}
